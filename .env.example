# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=siip
POSTGRES_USER=siip
POSTGRES_PASSWORD=             # set this

# ── Milvus ────────────────────────────────────────────────────
MILVUS_HOST=localhost
MILVUS_PORT=19530

# ── Neo4j ─────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=                # set this (min 8 chars)

# ── Scoring parameters ────────────────────────────────────────
ALPHA=0.4                      # weight of lex_sim vs sem_sim (0.0–1.0)
DIRICHLET_MU=2000              # Dirichlet prior for language model smoothing
MIN_SCORE=0.25                 # minimum similarity to store as Neo4j edge
TOP_K_MILVUS=5                 # top-k neighbors per chunk in Milvus ANN search
TOP_K_DRIVING_TERMS=5          # number of driving terms returned per edge

# ── Model ─────────────────────────────────────────────────────
SCINCL_MODEL=malteos/scincl    # HuggingFace model ID
SCINCL_CACHE_DIR=./.model_cache
