# ── Cloud-backed local dev (recommended) ─────────────────────────────────────
# Local and production share the SAME databases. Generate this file from your
# cloud credentials — do not hand-edit unless you know what you're doing:
#
#   cp deploy/free/credentials.env.example deploy/free/credentials.env
#   # fill in DATABASE_URL, NEO4J_URI, NEO4J_PASSWORD
#   bash deploy/free/link-local-env.sh
#
# Then: uvicorn api.main:app --host 0.0.0.0 --port 8080 --reload
# Push to main on GitHub → Fly redeploys code/UI automatically.

DATABASE_URL=postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
VECTOR_BACKEND=pgvector
POSTGRES_SSLMODE=require

NEO4J_URI=neo4j+s://xxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Scoring (match production)
ALPHA=0.4
ALPHA_LEX=0.3
ALPHA_SEM=0.5
ALPHA_CAT=0.2
DIRICHLET_MU=2000
MIN_SCORE=0.55

SCINCL_MODEL=malteos/scincl
SCINCL_CACHE_DIR=./.model_cache

# Optional — for local script runs; the UI also accepts a Gemini key in Settings
GEMINI_API_KEY=

# ── Optional: isolated Docker stack (legacy / offline) ───────────────────────
# Only use these if you run `docker compose up` and want a fully local copy.
# They are ignored when DATABASE_URL is set.
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5433
# POSTGRES_DB=siip
# POSTGRES_USER=siip
# POSTGRES_PASSWORD=
# MILVUS_HOST=localhost
# MILVUS_PORT=19530
# NEO4J_URI=bolt://localhost:7687
