# Copy to deploy/free/credentials.env and fill in.
# All values come from the three managed-service signups (Supabase, Neo4j Aura, Fly.io).
# This file is git-ignored.

# ── Supabase (Postgres + pgvector) ──────────────────────────────────────────
# Get from: Supabase Dashboard → your project → Project Settings → Database
#           → "Connection string" → URI tab → copy the "Direct connection" URL.
# It looks like: postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=

# ── Neo4j AuraDB Free ───────────────────────────────────────────────────────
# Get from: Neo4j Aura Console → your DB → "Connect" → copy URI + the password
#           you saved when you created it.
NEO4J_URI=neo4j+s://xxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ── Fly.io ──────────────────────────────────────────────────────────────────
# Browser auth via `flyctl auth login` works without a token. Set this only if
# you want non-interactive CI deploys: https://fly.io/user/personal_access_tokens
FLY_API_TOKEN=

# Optional: pick your Fly app name (must be globally unique, lowercase, dashes only)
FLY_APP_NAME=siip-armchair-akhil

# Optional: bake a Gemini key into the server so LLM explanations work without
# users having to paste their own key in the UI.
GEMINI_API_KEY=
